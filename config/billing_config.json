  "billing_types": {
    "token": {
      "description": "按 token 计费",
      "params": ["input_price_per_1k", "output_price_per_1k"]
    },
    "per_use": {
      "description": "按次计费（生成次数）",
      "params": ["price_per_use"]
    },
    "per_second": {
      "description": "按秒计费（视频/音频时长）",
      "params": ["price_per_second"]
    },
    "per_second_with_conditions": {
      "description": "按秒计费（支持按条件字段区分单价，如 mode/resolution）",
      "params": ["billing_conditions", "price_per_second"]
    },
    "per_model": {
      "description": "按模型计费（固定费用）",
      "params": ["price_per_model"]
    }
  },


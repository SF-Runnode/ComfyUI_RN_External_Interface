# Auto-detect text files and perform LF normalization
* text=auto

# Explicitly set LF for specific file types
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Binary files should not be touched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
*.zip binary
*.gz binary
*.tar binary

# Git related files
.gitattributes text eol=lf
.gitignore text eol=lf
